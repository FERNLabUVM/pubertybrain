Mplus VERSION 8.8 (Mac)
MUTHEN & MUTHEN
02/27/2026   9:45 AM

INPUT INSTRUCTIONS

  TITLE:	full model - FEMALE

  DATA:
  FILE IS dfmerged_mplus.dat;

  DEFINE:
    ! Rescale large variables to avoid variance > 1,000,000
    ! r indicates rescaled
    rT1_scort = subcort_vol_1 / 1000;
    rT2_scort = subcort_vol_2 / 1000;
    rT3_scort = subcort_vol_3 / 1000;
    rT4_scort = subcort_vol_4 / 1000;

  VARIABLE:	

  NAMES =
  numeric_id sex
  age_1 age_2 age_3 age_4
  subcort_vol_1 subcort_vol_2 subcort_vol_3 subcort_vol_4
  cort_vol_1 cort_vol_2 cort_vol_3 cort_vol_4
  fam_ID
  T1_totalGMV T2_totalGMV T3_totalGMV T4_totalGMV
  yfPDStiming yfPDStempo pfPDStiming pfPDStempo
  ymPDStiming ymPDStempo pmPDStiming pmPDStempo
  wmb wm6
  ela_plus;

  MISSING = ALL (-999);

  USEVAR =
  pfPDStiming pfPDStempo
  ela_plus
  wmb wm6
  rT1_scort rT2_scort rT3_scort rT4_scort;

  USEOBS are sex EQ 2;
  CLUSTER = fam_ID;

  ANALYSIS:
  TYPE = COMPLEX;
  ESTIMATOR = MLR;
  ITERATIONS = 10000;
  	
  MODEL:	intercept by rT1_scort-rT4_scort@1;
  	intercept;
  	[intercept];
  	slope BY rT1_scort@0
  		rT2_scort@1
  		rT3_scort@2
  		rT4_scort@3;
  	slope@0;
  	[slope];
  	
  	quad BY rT1_scort@0
  	        rT2_scort@1
  	        rT3_scort@4
  	        rT4_scort@9;
  	quad;
  	[quad];
  	
  	
  	intercept WITH slope@0;
  	intercept WITH quad;    ! remove covariances with quad, npd matrix
  	slope WITH quad@0;
  	
  	rT1_scort-rT4_scort (theta); !theta forces variances to be equal over time
  	[rT1_scort-rT4_scort@0];

  pfPDStiming;
  pfPDStempo;
  ela_plus;
  wmb wm6;

  !WM latent change score

  WMB_l BY wmb@1;
  WM6_l BY wm6@1;
  !the latent true scores yt1 and yt2

  wmb@0;
  wm6@0;
  !the residual variances of the observed variables (Yt1, Yt2) are fixed to 0

  [wmb@0];
  [wm6@0];
  !the intercepts of the observed variables (Yt1, Yt2) are fixed to 0

  WM6_l on WMB_l@1;
  !the autoregressive parameter (fixed to 1)

  Change by WM6_l@1;
  !the latent change factor (the factor loading is fixed to 1)

  WMB_l with Change;
  !the covariance between the latent true score at T1 (yt1) and the
  !latent change factor

  WMB_l;
  !the variance of the latent true score at T1 (yt1) is freely estimated

  [WMB_l];
  !the mean of the latent true score at T1 (yt1) is freely estimated

  Change;
  !the variance of the latent change factor is freely estimated

  [Change];
  !the mean of the latent change factor is freely estimated

  WM6_l@0;
  !the residual variance of the latent true score at T2 (yt2) is fixed to 0

  [WM6_l@0];
  !the intercept of the latent true score at T2 (yt2) is fixed to 0

  intercept WITH pfPDStiming pfPDStempo;
  slope WITH pfPDStempo@0;
  quad WITH pfPDStempo;
  pfPDStiming WITH pfPDStempo;

  slope ON pfPDStiming@0;
  quad ON pfPDStiming;
  intercept ON ela_plus;
  slope ON ela_plus@0;
  quad ON ela_plus;
  pfPDStiming ON ela_plus;
  pfPDStempo ON ela_plus;
  Change ON ela_plus;
  Change ON pfPDStiming pfPDStempo intercept quad;
  Change ON slope@0;

  MODEL INDIRECT:
  Change ind intercept ela_plus;
  Change ind pfPDStempo ela_plus; !exploratory

  OUTPUT: SAMPSTAT STANDARDIZED TECH4 CINTERVAL;

  !PLOT:
  !    TYPE = PLOT3;                       ! enables LOOP function plots
  !    SERIES = rT1_TOTAL-rT4_TOTAL (*);   ! optional: shows observed/model means over waves






*** WARNING in VARIABLE command
  When a subpopulation is analyzed with TYPE=COMPLEX, standard errors
  may be incorrect.  Use the SUBPOPULATION option instead of the
  USEOBSERVATIONS option to obtain correct standard errors.
*** WARNING in VARIABLE command
  Note that only the first 8 characters of variable names are used in the output.
  Shorten variable names to avoid any confusion.

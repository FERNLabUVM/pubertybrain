Mplus VERSION 8.8 (Mac)
MUTHEN & MUTHEN
08/22/2025   9:48 AM

INPUT INSTRUCTIONS

  TITLE:	GMV growth model- LATENT BASIS GROWTH - MALE

  DATA:	FILE IS gmv_mplus.dat;

  DEFINE:
    ! Rescale large variables to avoid variance > 1,000,000
    ! r indicates rescaled
    rT1_TOTAL = T1_totalGMV / 1000;
    rT2_TOTAL = T2_totalGMV / 1000;
    rT3_TOTAL = T3_totalGMV / 1000;
    rT4_TOTAL = T4_totalGMV / 1000;

  VARIABLE:	

  NAMES = sex age_1 age_3 age_2 age_4
          subcort_vol_1 subcort_vol_3 subcort_vol_2 subcort_vol_4
          cort_vol_1 cort_vol_3 cort_vol_2 cort_vol_4
          fam_ID T1_totalGMV T2_totalGMV T3_totalGMV T4_totalGMV
          numeric_id;

  MISSING = ALL (-999);
  USEVAR = rT1_TOTAL rT2_TOTAL rT3_TOTAL rT4_TOTAL;
  SUBPOPULATION = (sex NE 2);
  CLUSTER = fam_ID;

  ANALYSIS:

  TYPE = COMPLEX;
  ESTIMATOR = MLR;
  	
  MODEL:	intercept by rT1_TOTAL-rT4_TOTAL@1;
  	intercept;
  	[intercept];
  	slope BY rT1_TOTAL@0
  		rT2_TOTAL*
  		rT3_TOTAL*
  		rT4_TOTAL@1;
  	slope;
  	[slope];
  	intercept WITH slope;
  	rT1_TOTAL-rT4_TOTAL (theta); !theta forces variances to be equal over time
  	[rT1_TOTAL-rT4_TOTAL@0];

  OUTPUT: SAMPSTAT STANDARDIZED TECH4;

  PLOT:
  TYPE = PLOT3;
  SERIES = rT1_TOTAL-rT4_TOTAL (slope);



*** WARNING in VARIABLE command
  Note that only the first 8 characters of variable names are used in the output.
  Shorten variable names to avoid any confusion.
*** WARNING in PLOT command
  Note that only the first 8 characters of variable names are used in plots.
  If variable names are not unique within the first 8 characters, problems
  may occur.

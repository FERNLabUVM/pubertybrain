theme(
axis.text.x = element_text(angle = 45, hjust = 1),
axis.text.y = element_text(size = 9)
) +
labs(
title = "Correlation Matrix (Upper = Male, Lower = Female)",
subtitle = paste0("Only correlations with p < ", alpha_sig, " are shown (Pearson).")
)

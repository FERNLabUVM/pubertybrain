df %>%
select(ID, male, all_of(cols)) %>%
pivot_longer(
cols = all_of(cols),
names_to = "wave_raw",
values_to = "value"
) %>%
mutate(
wave = factor(wave_raw, levels = cols, labels = wave_labels),
family = family_name
)
}
# Pivot each family

names(dfygirls)
head(dfygirls)
#Make sure that everyone in your sample has years 0-5!
id_famid <- dfygirls %>%
distinct(ID, FAMID)              # FAMID is constant within ID
View(id_famid)
dfygirls <- id_famid %>%
tidyr::expand_grid(year = 0:5) %>%           # full ID x year grid
left_join(dfygirls, by = c("ID", "FAMID", "year")) %>%  # bring in observed rows
arrange(ID, year)
View(dfygirls)

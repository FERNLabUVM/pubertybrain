dfyboysPDSclean %>%
group_by(ID) %>%
summarise(n_nonmiss = sum(!is.na(ymPDSm))) %>%
filter(n_nonmiss < 2)  #should return zero rows
#Count of IDs retained:
dfyboysPDSclean %>%
summarize(n_IDs = n_distinct(ID))
head(dfyboysPDSclean)
#Some really quick plotting

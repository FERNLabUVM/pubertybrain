position = position_jitter(width = 0.03, height = 0), na.rm = TRUE) +
scale_x_continuous(breaks = 9:17, limits = c(9, 17), expand = c(0, 0)) +
scale_y_continuous(breaks = 1:4, limits = c(1, 4)) +

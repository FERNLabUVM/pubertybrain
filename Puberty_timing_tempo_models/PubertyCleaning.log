. foreach v of varlist ppds* {
  2.     // If string: map text codes to missing, then destring
.     capture confirm string variable `v'
  3.     if !_rc {
  4.         // normalize common text codes to empty (string-missing)
.         replace `v' = "" if inlist(strtrim(strlower(`v')), "n/a", "na", ".")
  5.         replace `v' = "" if inlist(strtrim(`v'), "99", "999")
  6.         destring `v', replace  // converts to numeric; empties become .
  7.     }
  8. 
.     // If numeric: set 99/999 to numeric missing
.     capture confirm numeric variable `v'
  9.     if !_rc {
 10.         replace `v' = . if inlist(`v', 99, 999)
 11.     }
 12. }
